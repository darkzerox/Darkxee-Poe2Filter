{
  "project": {
    "name": "DZX Filter POE2",
    "version": "0.5.9",
    "description": "Advanced Item Filter for Path of Exile 2",
    "author": "Darkxee",
    "repository": "https://github.com/darkzerox/Darkxee-Poe2Filter",
    "website": "https://darkzerox.github.io/Darkxee-Poe2Filter/"
  },
  "build": {
    "output_directory": "./",
    "css_directory": "dzx_filter/css",
    "js_directory": "dzx_filter/js",
    "filter_group_directory": "dzx_filter/filter_group",
    "backup_directory": "backup",
    "temp_directory": "temp",
    "output_game_filter_path": "%USERPROFILE%\\Documents\\My Games\\Path of Exile 2"
  },
  "sound_effects": {
    "available_types": [
      "type-01"
    ],
    "default_type": "type-01",
    "directory": "dzx_filter/soundeffect",
    "volume_levels": {
      "low": 100,
      "medium": 200,
      "high": 300
    }
  },
  "filter_variants": [
    {
      "name": "dzx-poe2",
      "description": "Main filter with all features",
      "group": "MAIN_GROUP",
      "sound_type": "type-01",
      "platforms": [
        "pc"
      ],
      "no_hide_variant": true,
      "enabled": true
    },
    {
      "name": "dzx-poe2-PS5",
      "description": "PS5 optimized version",
      "group": "MAIN_GROUP",
      "sound_type": "type-01",
      "platforms": [
        "ps5"
      ],
      "no_hide_variant": true,
      "enabled": true
    },
    {
      "name": "dzx-poe2-dont-rare",
      "description": "hide rare gear item",
      "group": "DONT_RARE_GROUP",
      "remove_sounds": false,
      "hide_items": false,
      "enabled": true,
      "platforms": [
        "pc"
      ],
      "no_hide_variant": false
    },
    {
      "name": "dzx-poe2-dont-rare-ps5",
      "description": "hide rare gear item",
      "group": "DONT_RARE_GROUP",
      "remove_sounds": true,
      "hide_items": false,
      "enabled": true,
      "platforms": [
        "ps5"
      ],
      "no_hide_variant": false
    }
  ],
  "special_variants": [],
  "filter_groups": {
    "MAIN_GROUP": [
      "scroll_of_wisdom.filter",
      "gold.filter",
      "gacha.filter",
      "key.filter",
      "rune.filter",
      "relics.filter",
      "talisman.filter",
      "soul_core.filter",
      "waystones.filter",
      "fragment.filter",
      "uncut_gems.filter",
      "support_gem.filter",
      "crafting.filter",
      "currency.filter",
      "content/idol.filter",
      "content/incursion.filter",
      "content/expedition.filter",
      "content/breach.filter",
      "content/abyssal.filter",
      "content/delirium.filter",
      "content/verisium.filter",
      "content/vaal.filter",
      "content/essences.filter",
      "content/ritual_omen.filter",
      "unique/olroths_legacy.filter",
      "unique/accessory.filter",
      "unique/armour.filter",
      "unique/flask.filter",
      "unique/jewel.filter",
      "unique/map.filter",
      "unique/weapon.filter",
      "unique/sanctum.filter",
      "gear/amulets.filter",
      "gear/belts.filter",
      "gear/jewel.filter",
      "gear/ring.filter",
      "gear/flasks.filter",
      "gear/charms.filter",
      "gear/rarity_unique.filter",
      "gear/rarity_rare.filter",
      "gear/rarity_magic.filter",
      "salvage.filter"
    ],
    "TEMPLE_GROUP": [
      "map_temple.filter",
      "content/incursion.filter",
      "content/ritual_omen.filter",
      "currency.filter",
      "gear/rarity_unique.filter",
      "gear/rarity_rare.filter",
      "gear/rarity_magic.filter"
    ],
    "DONT_RARE_GROUP": [
      "scroll_of_wisdom.filter",
      "gold.filter",
      "gacha.filter",
      "key.filter",
      "rune.filter",
      "relics.filter",
      "talisman.filter",
      "soul_core.filter",
      "waystones.filter",
      "fragment.filter",
      "uncut_gems.filter",
      "support_gem.filter",
      "crafting.filter",
      "currency.filter",
      "content/idol.filter",
      "content/incursion.filter",
      "content/expedition.filter",
      "content/breach.filter",
      "content/abyssal.filter",
      "content/delirium.filter",
      "content/verisium.filter",
      "content/vaal.filter",
      "content/essences.filter",
      "content/ritual_omen.filter",
      "unique/olroths_legacy.filter",
      "unique/accessory.filter",
      "unique/armour.filter",
      "unique/flask.filter",
      "unique/jewel.filter",
      "unique/map.filter",
      "unique/weapon.filter",
      "unique/sanctum.filter",
      "map_dont_rare.filter",
      "gear/amulets.filter",
      "gear/belts.filter",
      "gear/jewel.filter",
      "gear/ring.filter",
      "gear/flasks.filter",
      "gear/charms.filter",
      "gear/rarity_unique.filter",
      "gear/rarity_rare.filter",
      "gear/rarity_magic.filter",
      "salvage.filter"
    ]
  },
  "html_generation": {
    "template_directory": "templates",
    "use_external_assets": true,
    "minify_output": false,
    "generate_preview": true,
    "include_animations": true
  },
  "css_generation": {
    "include_filter_styles": true,
    "minify_output": false,
    "use_autoprefixer": false
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(levelname)s - %(message)s",
    "file": null
  },
  "validation": {
    "check_file_existence": true,
    "validate_filter_syntax": true,
    "warn_missing_sounds": true,
    "strict_mode": false
  },
  "optimization": {
    "enable_caching": false,
    "parallel_processing": false,
    "incremental_build": false,
    "backup_on_build": false
  }
}